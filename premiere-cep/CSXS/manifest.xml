<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest
    Version="7.0"
    ExtensionBundleId="com.chacha.WeClawSend.Premiere"
    ExtensionBundleVersion="1.6.3"
    ExtensionBundleName="WeClaw Send"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.chacha.WeClawSend.Premiere.panel" Version="1.6.3"/>
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="PPRO" Version="[25.0,99.9]"/>
        </HostList>
        <LocaleList>
            <Locale Code="All"/>
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="12.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.chacha.WeClawSend.Premiere.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./jsx/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>WeClaw Send</Menu>
                    <Geometry>
                        <Size>
                            <Height>640</Height>
                            <Width>380</Width>
                        </Size>
                        <MinSize>
                            <Height>420</Height>
                            <Width>300</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>1200</Height>
                            <Width>1200</Width>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
